{
  "manifest_version": 3,
  "name": "Moodle Task Hider",
  "version": "1.0.0",
  "description": "Moodleダッシュボードの不要な課題・小テストを非表示にできる拡張機能（復元可能）",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Moodle Task Hider"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
